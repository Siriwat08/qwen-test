# EditorConfig — รักษา coding style ให้สม่ำเสมอข้าม editors
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.gs]
indent_size = 2
max_line_length = 120

[*.html]
indent_size = 2

[*.yml]
indent_size = 2

[*.json]
indent_size = 2

[Makefile]
indent_style = tab
